          "width": "fill_container",
          "layout": "vertical",
          "gap": 14,
          "alignItems": "center",
          "children": [
            {
              "type": "text",
              "id": "fNzAr",
              "name": "h1",
              "fill": "#FFFFFF",
              "textGrowth": "fixed-width",
              "width": 800,
              "content": "Every tool promises to save you time.\nNone of them talk to each other.",
              "lineHeight": 1.15,
              "textAlign": "center",
              "fontFamily": "Manrope",
              "fontSize": 42,
              "fontWeight": "800"
            },
            {
              "type": "text",
              "id": "lQNHG",
              "name": "h2",
              "fill": "#5a5864",
              "content": "Your tools are siloed. LUCI connects them so nothing falls through the cracks.",
